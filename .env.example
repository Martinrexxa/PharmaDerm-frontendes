# ============================================================
# PharmaDerm — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env al repositorio (está en .gitignore).
# ============================================================

# ── EmailJS ──────────────────────────────────────────────────
# Obtén estos valores en https://www.emailjs.com/
# 1. Crea una cuenta → Email Services → conecta Gmail/Outlook
# 2. Email Templates → crea plantilla de orden y de cita
# 3. Account → API Keys → copia Public Key

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_ORDER_TEMPLATE_ID_ES=
VITE_EMAILJS_ORDER_TEMPLATE_ID_EN=
VITE_EMAILJS_APPOINTMENT_TEMPLATE_ID_ES=
VITE_EMAILJS_APPOINTMENT_TEMPLATE_ID_EN=
VITE_EMAILJS_ROUTINE_TEMPLATE_ID_ES=
VITE_EMAILJS_ROUTINE_TEMPLATE_ID_EN=
VITE_EMAILJS_PUBLIC_KEY=

# ── Supabase ──────────────────────────────────────────────────
# Obtén estos valores en https://supabase.com/
# 1. Crea proyecto → Settings → API
# 2. Copia Project URL y anon public key

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Configuración regional por defecto ────────────────────────
VITE_DEFAULT_CURRENCY=USD
VITE_DEFAULT_COUNTRY=DO
VITE_DOP_EXCHANGE_RATE=59.40

# ── Modo de datos ────────────────────────────────────────────
# "local"    → usa solo localStorage (sin backend)
# "supabase" → usa Supabase cuando las variables estén configuradas
VITE_DATA_MODE=local
